<profile name="rss.Posts" type="sync">
    <key name="category" value="eventfeed"/>
    <key name="enabled" value="false"/>
    <key name="use_accounts" value="false"/>
    <key name="destinationtype" value="online"/>
    <key name="hidden" value="true"/>
    <key name="displayname" value="News posts"/>

    <schedule enabled="true"
              interval="720"
              days="1,2,3,4,5,6,7"
              syncconfiguredtime=""
              time=""/>

    <profile name="rss-posts" type="client">
        <key name="Sync Direction" value="from-remote"/>
    </profile>
</profile>
